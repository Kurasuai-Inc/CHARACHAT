{
  "name": "@kurasuai-inc/charahome-api",
  "version": "0.28.0",
  "description": "CHARAHOME API SDK - API Client for Node.js, handlers for Next.js, and IPC helpers for Electron",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client-entry.d.ts",
      "import": "./dist/client-entry.mjs",
      "require": "./dist/client-entry.js"
    },
    "./electron": {
      "types": "./dist/electron/index.d.ts",
      "import": "./dist/electron/index.mjs",
      "require": "./dist/electron/index.js"
    },
    "./node-cache": {
      "types": "./dist/node-cache.d.ts",
      "import": "./dist/node-cache.mjs",
      "require": "./dist/node-cache.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client-entry.ts src/electron/index.ts src/node-cache.ts --format cjs,esm --dts && node scripts/fix-dts-namespace.mjs",
    "dev": "tsup src/index.ts src/client-entry.ts src/electron/index.ts src/node-cache.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "electron": ">=28.0.0",
    "fzstd": ">=0.1.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "electron": {
      "optional": true
    },
    "fzstd": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "dotenv": "^17.2.3",
    "electron": "^33.0.0",
    "fzstd": "^0.1.1",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "charahome",
    "api",
    "sdk",
    "nextjs",
    "electron"
  ],
  "author": "Kurasuai Inc.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kurasuai-Inc/CHARAHOME-JS-SDKs.git",
    "directory": "packages/api"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
